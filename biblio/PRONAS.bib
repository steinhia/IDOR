@article{keary_corpus_2009,
	title = {Corpus callosum volume and neurocognition in autism},
	volume = {39},
	issn = {1573-3432},
	doi = {10.1007/s10803-009-0689-4},
	abstract = {The corpus callosum has recently been considered as an index of interhemispheric connectivity. This study applied a novel volumetric method to examine the size of the corpus callosum in 32 individuals with autism and 34 age-, gender- and IQ-matched controls and to investigate the relationship between this structure and cognitive measures linked to interhemispheric functioning. Participants with autism displayed reductions in total corpus callosum volume and in several of its subdivisions. Relationships were also observed between volumetric alterations and performance on several cognitive tests including the Tower of Hanoi test. These findings provide further evidence for anatomical alterations in the corpus callosum in autism, but warrant additional studies examining the relationship of this structure and specific measures of interhemispheric connectivity.},
	language = {eng},
	number = {6},
	journal = {Journal of Autism and Developmental Disorders},
	author = {Keary, Christopher J. and Minshew, Nancy J. and Bansal, Rahul and Goradia, Dhruman and Fedorov, Serguei and Keshavan, Matcheri S. and Hardan, Antonio Y.},
